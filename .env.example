# ─────────────────────────────────────────────────
# Sahayak 1092 – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# ── Twilio ──────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── OpenAI / Grok (NLU + Decision Engine) ──────
OPENAI_API_KEY=your_openai_api_key
# Optional: switch to Grok by setting the base URL
# OPENAI_BASE_URL=https://api.x.ai/v1

# ── Deepgram (STT fallback) ────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Bhashini (STT + TTS primary) ───────────────
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_USER_ID=your_bhashini_user_id
BHASHINI_PIPELINE_URL=https://dhruva-api.bhashini.gov.in/services/inference

# ── Supabase ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── Server ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
BASE_URL=https://your-ngrok-url.ngrok-free.app
