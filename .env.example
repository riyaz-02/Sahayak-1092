# Sahayak 1092 - Environment Variables
# Copy this file to `.env` and fill in local values.
# Keep real credentials out of git.

# App/runtime
SAHAYAK_ENV=development
DEBUG=true
DEMO_MODE=true
HOST=0.0.0.0
PORT=8000
BASE_URL=http://localhost:8000
CORS_ORIGINS=*

# Dashboard
SAHAYAK_API_URL=http://localhost:8000
NEXT_PUBLIC_SAHAYAK_API_URL=http://localhost:8000
# Server-side Next.js proxy key. Keep blank in local demo mode.
SAHAYAK_DASHBOARD_API_KEY=

# Twilio / telephony
# Required only for real phone calls. Local test pipeline works without these.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TRANSFER_MODE=mock

# AI / LLM provider
# Leave empty for dependency/import tests. Configure for live AI behavior.
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o
LLM_PROVIDER_TIMEOUT_SEC=8
# auto = LLM when OPENAI_API_KEY exists, deterministic fallback otherwise.
# deterministic = always offline heuristics for local demos/tests.
ANALYSIS_PROVIDER=auto
# deterministic = offline hashing embeddings for demo/tests.
# openai/auto can be used in production when OPENAI_API_KEY is configured.
EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
VECTOR_SEARCH_LIMIT=10
# Raw vector cosine threshold for DB-side candidate retrieval. Final blended
# score still uses SIMILARITY_MATCH_THRESHOLD below.
VECTOR_DB_MATCH_THRESHOLD=0.15

# Sarvam AI / Indian language voice
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_PACE=0.95
SARVAM_TTS_TEMPERATURE=0.35

# Legacy Bhashini fallback, optional
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_PIPELINE_URL=https://dhruva-api.bhashini.gov.in/services/inference

# STT/TTS fallbacks
DEEPGRAM_API_KEY=
GEMINI_API_KEY=
STT_PROVIDER_ORDER=sarvam,deepgram,google,openai_whisper
TTS_PROVIDER_ORDER=sarvam,google,edge,openai
VOICE_PROVIDER_TIMEOUT_SEC=12
# Enables in-memory cache for common Vachan/routing phrases after first synthesis.
TTS_PHRASE_CACHE_ENABLED=true

# Supabase / database
# Local imports work without these. Live persistence requires both.
SUPABASE_URL=
# Server backend writes should use the service-role key when RLS is enabled.
# Never expose this key to the browser or Next.js public env.
SUPABASE_SERVICE_ROLE_KEY=
# Legacy/fallback key. An anon key can read public data, but RLS may block writes.
SUPABASE_KEY=

# Redis / live call state
# Phase 2 will use this when configured; local fallback remains available.
REDIS_URL=

# Security / production hardening
# Defaults are relaxed in DEMO_MODE=true and strict in DEMO_MODE=false.
VALIDATE_TWILIO_SIGNATURES=false
DASHBOARD_AUTH_REQUIRED=false
DASHBOARD_API_KEY=
DASHBOARD_ADMIN_KEY=
DASHBOARD_READONLY_KEY=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=180
MUTATION_RATE_LIMIT_PER_MINUTE=60
REQUEST_ID_HEADER=X-Request-ID
MASK_PII_IN_LOGS=true
DATA_RETENTION_DAYS=180

# Decision thresholds
LOW_CONFIDENCE_THRESHOLD=0.5
LOW_CONFIDENCE_MAX_ATTEMPTS=2
AUTONOMOUS_CONFIDENCE_THRESHOLD=0.7
SIMILARITY_CONFIDENCE_THRESHOLD=0.6
SIMILARITY_MATCH_THRESHOLD=0.7
EXTREME_URGENCY_THRESHOLD=0.9
HIGH_HELP_ALERT_TIMEOUT_SEC=120
HIGH_HELP_ALERT_DEMO_TIMEOUT_SEC=20

# Voice activity detection
VAD_SILENCE_THRESHOLD=0.02
VAD_SILENCE_DURATION_MS=1500
VAD_BUFFER_MAX_DURATION_MS=15000
